generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Company {
  id             String    @id @default(uuid())
  name           String
  website        String?
  industry       String?
  employeeCount  Int?
  fundingStage   String?
  linkedinUrl    String?
  notes          String?
  status         String    @default("prospect")
  tags           String[]
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @default(now()) @updatedAt

  contacts       Contact[]
  deals          Deal[]
  jobOrders      JobOrder[]
  activities     Activity[]
}

model Contact {
  id              String    @id @default(uuid())
  companyId       String?
  firstName       String
  lastName        String
  email           String?
  phone           String?
  title           String?
  linkedinUrl     String?
  linkedinId      String?
  googleContactId String?
  source          String?
  tags            String[]
  notes           String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @default(now()) @updatedAt

  company         Company?  @relation(fields: [companyId], references: [id], onDelete: SetNull)
  deals           Deal[]
  activities      Activity[]
  jobOrders       JobOrder[]
  trackingEvents  TrackingEvent[]
  campaignMembers CampaignMember[]
}

model Deal {
  id             String    @id @default(uuid())
  companyId      String?
  contactId      String?
  title          String
  stage          String    @default("prospect")
  estimatedValue Decimal?  @db.Decimal(12, 2)
  feePercentage  Decimal?  @db.Decimal(5, 2)
  notes          String?
  closedAt       DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @default(now()) @updatedAt

  company        Company?  @relation(fields: [companyId], references: [id], onDelete: SetNull)
  contact        Contact?  @relation(fields: [contactId], references: [id], onDelete: SetNull)
  activities     Activity[]
}

model JobOrder {
  id                 String    @id @default(uuid())
  companyId          String?
  contactId          String?
  title              String
  roleTier           String?
  baseSalaryMin      Decimal?  @db.Decimal(12, 2)
  baseSalaryMax      Decimal?  @db.Decimal(12, 2)
  feePercentage      Decimal?  @db.Decimal(5, 2)
  exclusivityStart   DateTime?
  exclusivityDays    Int       @default(14)
  icpNotes           String?
  quotaExpectations  String?
  teamCultureNotes   String?
  methodologyPref    String[]
  status             String    @default("active")
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @default(now()) @updatedAt

  company            Company?  @relation(fields: [companyId], references: [id], onDelete: SetNull)
  contact            Contact?  @relation(fields: [contactId], references: [id], onDelete: SetNull)
  applications       Application[]
}

model Candidate {
  id                 String    @id @default(uuid())
  firstName          String
  lastName           String
  email              String?
  phone              String?
  linkedinUrl        String?
  linkedinId         String?
  currentTitle       String?
  currentCompany     String?
  location           String?
  yearsExperience    Int?
  skills             String[]
  gtmMethodology     String[]
  quotaAttainment    Json?
  salaryExpectation  Decimal?  @db.Decimal(12, 2)
  availability       String?
  reasonForLooking   String?
  resumeDriveId      String?
  source             String?
  referralSource     String?
  vettingStage1      Boolean   @default(false)
  vettingStage2      Boolean   @default(false)
  overallScore       Decimal?  @db.Decimal(5, 2)
  tags               String[]
  notes              String?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @default(now()) @updatedAt

  applications       Application[]
  campaignMembers    CampaignMember[]
}

model Application {
  id                 String    @id @default(uuid())
  candidateId        String
  jobOrderId         String
  stage              String    @default("sourced")
  submittedAt        DateTime?
  interviewDate      DateTime?
  offerDate          DateTime?
  placedDate         DateTime?
  guaranteeEndDate   DateTime?
  feeAmount          Decimal?  @db.Decimal(12, 2)
  invoiceStatus      String?
  notes              String?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @default(now()) @updatedAt

  candidate          Candidate @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  jobOrder           JobOrder  @relation(fields: [jobOrderId], references: [id], onDelete: Cascade)

  @@unique([candidateId, jobOrderId])
}

model Activity {
  id                 String    @id @default(uuid())
  contactId          String?
  companyId          String?
  dealId             String?
  type               String
  subject            String?
  body               String?
  direction          String?
  channel            String?
  occurredAt         DateTime  @default(now())
  createdAt          DateTime  @default(now())

  contact            Contact?  @relation(fields: [contactId], references: [id], onDelete: SetNull)
  company            Company?  @relation(fields: [companyId], references: [id], onDelete: SetNull)
  deal               Deal?     @relation(fields: [dealId], references: [id], onDelete: SetNull)
  trackingEvents     TrackingEvent[]
}

model TrackingEvent {
  id              String    @id @default(uuid())
  activityId      String?
  contactId       String?
  eventType       String    // "open" or "click"
  linkUrl         String?   // Destination URL if click
  ipAddress       String?
  userAgent       String?
  deviceType      String?   // "mobile", "desktop", "tablet"
  browser         String?
  os              String?
  geoCity         String?
  geoRegion       String?
  geoCountry      String?
  occurredAt      DateTime  @default(now())

  activity        Activity? @relation(fields: [activityId], references: [id], onDelete: SetNull)
  contact         Contact?  @relation(fields: [contactId], references: [id], onDelete: SetNull)
}

model Post {
  id           String    @id @default(uuid())
  content      String    @db.Text
  topic        String?
  format       String?
  tone         String?
  status       String    @default("draft") // draft, scheduled, published
  scheduledFor DateTime?
  publishedAt  DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @default(now()) @updatedAt
}

model Sequence {
  id          String   @id @default(uuid())
  name        String
  description String?
  steps       SequenceStep[]
  campaigns   Campaign[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @default(now()) @updatedAt
}

model SequenceStep {
  id          String   @id @default(uuid())
  sequenceId  String
  type        String   // "email", "linkedin_view", "linkedin_connect", "linkedin_message"
  orderIndex  Int
  delayDays   Int      @default(1)
  content     String?  @db.Text // Email or message template
  subject     String?  // For emails
  variants    Json?    // For A/B testing
  condition   String?  // Branching conditions
  createdAt   DateTime @default(now())
  updatedAt   DateTime @default(now()) @updatedAt

  sequence    Sequence @relation(fields: [sequenceId], references: [id], onDelete: Cascade)
  campaignMembers CampaignMember[]
}

model Campaign {
  id          String   @id @default(uuid())
  name        String
  sequenceId  String
  status      String   @default("draft") // "draft", "active", "paused", "completed"
  metrics     Json?    
  createdAt   DateTime @default(now())
  updatedAt   DateTime @default(now()) @updatedAt

  sequence    Sequence @relation(fields: [sequenceId], references: [id], onDelete: Cascade)
  members     CampaignMember[]
}

model CampaignMember {
  id              String   @id @default(uuid())
  campaignId      String
  contactId       String?
  candidateId     String?
  currentStepId   String?
  status          String   @default("active") // "active", "paused", "replied", "completed", "bounced"
  nextExecutionAt DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @default(now()) @updatedAt

  campaign        Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  contact         Contact? @relation(fields: [contactId], references: [id], onDelete: SetNull)
  candidate       Candidate? @relation(fields: [candidateId], references: [id], onDelete: SetNull)
  currentStep     SequenceStep? @relation(fields: [currentStepId], references: [id], onDelete: SetNull)

  @@unique([campaignId, contactId])
  @@unique([campaignId, candidateId])
}
